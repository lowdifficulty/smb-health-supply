{
  "framework": null,
  "buildCommand": "node scripts/build-deploy.mjs",
  "installCommand": "npm install",
  "outputDirectory": "deploy",
  "cleanUrls": false,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/(login|dashboard|tracking|billing|catalog|order|ivr|accounts|alerts|asg-data|asg|skin-substitutes)(/.*)?",
      "destination": "/portal/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/portal/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/wp-content/uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
