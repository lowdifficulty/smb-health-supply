# ASG Google Sheet daily monitor (see: npm run setup-asg-google)
ASG_GOOGLE_SERVICE_ACCOUNT_PATH=secrets/google-service-account.json
# Or paste full JSON for Vercel/serverless:
# ASG_GOOGLE_SERVICE_ACCOUNT_JSON=
ASG_NOTIFY_EMAIL=mlewis@smbhealthsupply.com

IVR_NOTIFY_EMAIL=mlewis@smbhealthsupply.com
ASG_NOTIFY_EMAIL=mlewis@smbhealthsupply.com
IVR_EMAIL_FROM=SMB Health Supply <notifications@smbhealthsupply.com>
APP_URL=https://smb-health-supply.vercel.app

# Upstash Redis (Vercel Marketplace → Upstash Redis) — required for live ASG data + IVR
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Sheets ASG monitor — paste full service account JSON (Production on Vercel)
ASG_GOOGLE_SERVICE_ACCOUNT_JSON=
# Local alternative:
ASG_GOOGLE_SERVICE_ACCOUNT_PATH=secrets/google-service-account.json

# Legacy Vercel KV names (still supported if present)
KV_REST_API_URL=
KV_REST_API_TOKEN=
